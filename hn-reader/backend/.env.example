# Database Configuration (Neon PostgreSQL)
# Get your connection string from: https://neon.tech
# Example: postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/hn_reader?sslmode=require
DATABASE_URL="your_neon_connection_string_here"

# ==========================================
# AI Provider Configuration
# ==========================================
# Choose mode: 'auto', 'mistral', 'groq', 'gemini', or 'openai'
#
# 'auto' (RECOMMENDED for free usage): Automatically tries providers in order until one succeeds
#        Great for maximizing free tier usage across multiple providers
#
# Single provider modes: Use a specific provider only
AI_PROVIDER=auto

# AUTO Mode: Provider rotation order (comma-separated)
# When AI_PROVIDER=auto, it will try these providers in order
# Recommended order: mistral,groq,gemini (all have generous free tiers)
AUTO_PROVIDERS=mistral,groq,gemini

# ==========================================
# Mistral AI Configuration (RECOMMENDED - Very affordable/free credits)
# ==========================================
# Get it from: https://console.mistral.ai/api-keys/
# Free credits on signup + very low cost
MISTRAL_API_KEY="your_mistral_api_key_here"
MISTRAL_MODEL=open-mistral-7b
# Alternative models:
# - open-mistral-7b (cheapest: $0.25/1M tokens)
# - mistral-small-latest (better quality: $1/1M tokens)

# ==========================================
# Groq Configuration (Excellent free tier)
# ==========================================
# Get it from: https://console.groq.com/keys
# Very generous free tier with fast inference
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL=llama-3.1-8b-instant
# Alternative models:
# - llama-3.1-8b-instant (fast and free)
# - mixtral-8x7b-32768 (longer context)

# ==========================================
# Google Gemini Configuration (Good free tier)
# ==========================================
# Get it from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL=gemini-2.5-flash
# Alternative: gemini-1.5-flash

# ==========================================
# OpenAI Configuration (Paid, higher quality)
# ==========================================
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_MODEL=gpt-4o-mini

# ==========================================
# Advanced AI Configuration (Optional)
# ==========================================
# Timeout for Gemini requests (milliseconds)
GEMINI_TIMEOUT_MS=60000

# Chunk size for processing large comment threads (characters)
# Larger = fewer API calls but needs more context window
SUMMARY_CHUNK_CHARS=15000

# Maximum number of chunks to process per story
MAX_SUMMARY_CHUNKS=50

# ==========================================
# Server Configuration
# ==========================================
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
