# Database Configuration (Neon PostgreSQL)
# Sign up at https://neon.tech and create a project
# Copy your connection string here
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech/hn_reader?sslmode=require"

# AI Provider Configuration
# Choose: 'openai' or 'gemini' (default: gemini)
AI_PROVIDER=gemini

# OpenAI Configuration (if using AI_PROVIDER=openai)
# Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-xxxxxxxxxxxxx"
OPENAI_MODEL=gpt-4o-mini

# Google Gemini Configuration (if using AI_PROVIDER=gemini)
# Get it from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
GEMINI_MODEL=gemini-2.5-flash

# These are already configured, you don't need to change them
PORT=8000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

